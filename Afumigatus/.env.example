# Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control - it's listed in .gitignore

# Galaxy API Key
# Get this from: https://usegalaxy.org/user/preferences/manage_api_key
# 1. Log in to usegalaxy.org
# 2. Click User > Preferences > Manage API Key
# 3. Copy your API key and paste below
GALAXY_API_KEY=your_galaxy_api_key_here

# Gemini API Key (if using Google's Gemini API)
# Get this from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Token (if needed for GitHub API access)
# Get this from: https://github.com/settings/tokens
# Choose appropriate scopes based on your needs
GITHUB_TOKEN=your_github_token_here

# Galaxy Instance URL (optional, defaults to https://usegalaxy.org)
# GALAXY_URL=https://usegalaxy.org
