# Use a Node.js base image
FROM node:22-slim

# Install system dependencies
RUN apt-get update && apt-get install -y  \
    curl \
    git \
    python3 \
    python3-pip \
    jq  \
    pipx \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

# Install Gemini CLI globally
RUN npm install -g @google/gemini-cli

# Set the working directory
WORKDIR /app

# The user will need to provide their API key at runtime
ENV GEMINI_API_KEY=""

# Optional: Add an entrypoint that ensures the API key is present
# and allows for interactive or headless execution
CMD ["gemini"]
